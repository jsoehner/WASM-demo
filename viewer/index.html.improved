<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; upgrade-insecure-requests;">
    <title>Multi-Provider WASM Agent</title>
    <style>
        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --error: #dc2626;
            --success: #16a34a;
            --warning: #ca8a04;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            max-width: 900px;
            margin: 0 auto;
            padding: 1rem;
            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
            min-height: 100vh;
        }
        .container {
            background: white;
            padding: 2rem;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
            position: relative;
        }
        h1 {
            color: #1e293b;
            margin: 0 0 1.5rem 0;
            font-size: 1.75rem;
            border-bottom: 2px solid #e2e8f0;
            padding-bottom: 1rem;
        }
        .form-group {
            margin-bottom: 1.25rem;
        }
        label {
            display: block;
            font-weight: 500;
            color: #475569;
            margin-bottom: 0.5rem;
        }
        input, select {
            padding: 0.75rem;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 1rem;
            width: 100%;
            box-sizing: border-box;
            transition: all 0.2s;
        }
        input:focus, select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }
        button {
            background: var(--primary);
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            width: 100%;
        }
        button:hover:not(:disabled) {
            background: var(--primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
        }
        button:disabled {
            background: #94a3b8;
            cursor: not-allowed;
            transform: none;
        }
        #log {
            background: #1e293b;
            color: #39ff14;
            padding: 1rem;
            white-space: pre-wrap;
            margin-top: 1rem;
            min-height: 150px;
            border-radius: 8px;
            max-height: 500px;
            overflow-y: auto;
            font-family: 'Fira Code', monospace;
            font-size: 0.9rem;
        }
        .error {
            color: #fca5a5;
            border-left: 4px solid var(--error);
            padding-left: 1rem;
        }
        .success {
            color: #86efac;
            border-left: 4px solid var(--success);
        }
        .warning {
            color: var(--warning);
            border-left: 4px solid var(--warning);
        }
        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
            margin-right: 8px;
            vertical-align: middle;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        .info-box {
            background: #eff6ff;
            border: 1px solid #dbeafe;
            border-radius: 8px;
            padding: 1rem;
            margin: 1rem 0;
            color: #1e40af;
            font-size: 0.9rem;
        }
        .status-bar {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: #f1f5f9;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.85rem;
            color: #64748b;
        }
        .provider-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }
        .form-group.full-width {
            grid-column: 1 / -1;
        }
        .config-toggle {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            padding: 1rem;
            border-radius: 8px;
            margin: 1rem 0;
            cursor: pointer;
            font-size: 0.9rem;
        }
        .config-toggle:hover {
            background: #f1f5f9;
        }
        #api-key {
            margin-top: 0.5rem;
        }
        .history-section {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid #e2e8f0;
        }
        .history-item {
            background: #f8fafc;
            padding: 0.75rem;
            border-radius: 6px;
            margin: 0.5rem 0;
            font-size: 0.85rem;
            color: #64748b;
        }
        .btn-small {
            padding: 0.4rem 0.75rem;
            font-size: 0.85rem;
            margin-left: 0.5rem;
            width: auto;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🤖 Multi-Provider WASM Agent</h1>
        
        <div class="status-bar" id="status">Status: Ready</div>
        
        <div class="provider-section">
            <div class="form-group">
                <label for="provider">Select Provider</label>
                <select id="provider" onchange="saveConfig()">
                    <option value="openai">OpenAI / Open WebUI</option>
                    <option value="ollama">Ollama (Native)</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="model-id">Model ID</label>
                <input type="text" id="model-id" value="llama3" placeholder="e.g., llama3, gpt-4o" oninput="saveConfig()">
            </div>
            
            <div class="form-group">
                <label for="api-url">API URL</label>
                <input type="text" id="api-url" value="http://localhost:11434/api" placeholder="http://localhost:11434/api" oninput="saveConfig()">
            </div>
            
            <div class="form-group full-width">
                <label for="api-key">API Key (Optional)</label>
                <input type="password" id="api-key" placeholder="Enter your API key (stored locally)" oninput="saveConfig()">
                <button type="button" onclick="togglePasswordVisibility()" style="margin-top: 0.5rem; background: #64748b; width: auto; padding: 0.4rem;">Show/Hide</button>
            </div>
        </div>
        
        <div class="form-group">
            <label for="prompt">Your Prompt</label>
            <textarea id="prompt" rows="3" value="Calculate the length of 'WebAssembly'." placeholder="Enter your prompt here..." oninput="saveConfig()"></textarea>
        </div>
        
        <button id="run-btn" onclick="runAgent()">⚡ Execute Agent</button>
        
        <div id="log">Ready. Configure settings above, then click Execute.</div>
        
        <button type="button" onclick="toggleHistory()" class="config-toggle">📜 Toggle History</button>
        
        <div id="history-section" style="display: none;" class="history-section">
            <h3>Conversation History</h3>
            <div id="history-list" style="margin-top: 0.5rem;"></div>
            <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem;">
                <button onclick="exportConversation()" class="btn-small">💾 Export</button>
                <button onclick="clearHistory()" class="btn-small">🗑️ Clear</button>
            </div>
        </div>
    </div>
    
    <script>
        // Initialize WASM
        let wasmAgent;
        
        async function init() {
            try {
                const initModule = await import('./pkg/wasm_agent.js');
                console.log('WASM initialized');
                return initModule;
            } catch (error) {
                log(`Initialization failed: ${error}`, 'error');
                return null;
            }
        }
        
        async function runAgent() {
            const log = document.getElementById('log');
            const status = document.getElementById('status');
            log.textContent = "Initializing...";
            log.className = "";
            
            try {
                const provider = document.getElementById('provider').value;
                const modelId = document.getElementById('model-id').value;
                const apiUrl = document.getElementById('api-url').value;
                const apiKey = document.getElementById('api-key').value;
                const prompt = document.getElementById('prompt').value;
                
                if (!modelId.trim()) {
                    log("Please enter a model ID.", 'error');
                    return;
                }
                
                if (!apiUrl.trim() || !apiUrl.startsWith('http')) {
                    log("Invalid API URL. Must start with http:// or https://", 'error');
                    return;
                }
                
                // Initialize WASM if not done
                if (!wasmAgent) {
                    const initModule = await init();
                    if (!initModule) return;
                    const AgentClass = initModule.Agent;
                    wasmAgent = new AgentClass(apiUrl, apiKey, provider);
                }
                
                status.textContent = "Status: Processing...";
                log.textContent = `Running on ${provider.toUpperCase()} with ${modelId}...`;
                
                const startTime = Date.now();
                const result = await wasmAgent.run_task(modelId, prompt);
                const duration = Date.now() - startTime;
                
                log(`\n✅ Response in ${duration}ms:\n\n${result}`, 'success');
                saveHistory(prompt, result, duration);
                
                status.textContent = "Status: Ready";
            } catch (error) {
                let errorMessage = "Error: " + error;
                const errorMsg = error.toString();
                
                if (errorMsg.includes('429') || errorMsg.includes('rate limit')) {
                    errorMessage += '\n\n⚠️ Rate limit exceeded. Please wait a moment and try again.';
                } else if (errorMsg.includes('401') || errorMsg.includes('unauthorized')) {
                    errorMessage += '\n\n⚠️ Invalid API key. Please check your API key.';
                } else if (errorMsg.includes('503') || errorMsg.includes('unavailable')) {
                    errorMessage += '\n\n⚠️ Service unavailable. The LLM server may be overloaded.';
                } else if (errorMsg.includes('network') || errorMsg.includes('timeout')) {
                    errorMessage += '\n\n⚠️ Network error. Please check your connection.';
                }
                
                log(errorMessage, 'error');
                status.textContent = "Status: Error";
            }
        }
        
        function log(message, type = 'info') {
            const log = document.getElementById('log');
            log.textContent += message;
            log.className = type;
            log.scrollTop = log.scrollHeight;
        }
        
        function saveConfig() {
            const config = {
                provider: document.getElementById('provider').value,
                modelId: document.getElementById('model-id').value,
                apiUrl: document.getElementById('api-url').value,
                apiKey: document.getElementById('api-key').value,
                prompt: document.getElementById('prompt').value
            };
            localStorage.setItem('wasm-agent-config', JSON.stringify(config));
        }
        
        function loadConfig() {
            try {
                const saved = localStorage.getItem('wasm-agent-config');
                if (saved) {
                    const config = JSON.parse(saved);
                    document.getElementById('provider').value = config.provider;
                    document.getElementById('model-id').value = config.modelId;
                    document.getElementById('api-url').value = config.apiUrl;
                    document.getElementById('api-key').value = config.apiKey;
                    document.getElementById('prompt').value = config.prompt;
                }
            } catch (e) {
                console.error('Failed to load saved config:', e);
            }
        }
        
        function togglePasswordVisibility() {
            const input = document.getElementById('api-key');
            input.type = input.type === 'password' ? 'text' : 'password';
        }
        
        function saveHistory(prompt, response, duration) {
            const historyItem = {
                prompt: prompt.substring(0, 50) + '...',
                response: response.substring(0, 100) + '...',
                duration: duration,
                timestamp: new Date().toLocaleTimeString()
            };
            
            let history = JSON.parse(localStorage.getItem('wasm-agent-history') || '[]');
            history.unshift(historyItem);
            localStorage.setItem('wasm-agent-history', JSON.stringify(history));
        }
        
        function getHistory() {
            return JSON.parse(localStorage.getItem('wasm-agent-history') || '[]');
        }
        
        function displayHistory() {
            const history = getHistory();
            const historyList = document.getElementById('history-list');
            
            if (history.length === 0) {
                historyList.innerHTML = '<p style="color: #94a3b8;">No conversation history yet.</p>';
                return;
            }
            
            historyList.innerHTML = history.map(item => `
                <div class="history-item">
                    <div><strong>${item.timestamp}</strong> (${item.duration}ms)</div>
                    <div style="margin: 0.25rem 0;"><span style="color: #94a3b8;">Q:</span> ${item.prompt}</div>
                    <div style="margin: 0.25rem 0;"><span style="color: #39ff14;">A:</span> ${item.response}</div>
                </div>
            `).join('');
        }
        
        function toggleHistory() {
            const section = document.getElementById('history-section');
            const isVisible = section.style.display === 'block';
            section.style.display = isVisible ? 'none' : 'block';
            
            if (!isVisible) {
                displayHistory();
            }
        }
        
        function exportConversation() {
            const history = getHistory();
            const content = history.map(item => `### ${item.timestamp} (${item.duration}ms)\n\nQ: ${item.prompt}\n\nA: ${item.response}`).join('\n\n');
            
            const blob = new Blob([content], { type: 'text/markdown' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = `conversation-${new Date().toISOString().slice(0, 10)}.md`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
        }
        
        function clearHistory() {
            if (confirm('Are you sure you want to clear all conversation history?')) {
                localStorage.removeItem('wasm-agent-history');
                displayHistory();
                log('History cleared.', 'info');
            }
        }
        
        // Load config on page load
        window.addEventListener('load', loadConfig);
        
        // Load history if exists
        document.addEventListener('DOMContentLoaded', () => {
            displayHistory();
        });
    </script>
</body>
</html>"