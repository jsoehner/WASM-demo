# WASM LLM Agent Environment Variables
# Copy this file to .env and fill in your values

# Provider selection (default: openrouter)
# Options: openrouter, openai, ollama
PROVIDER=openrouter

# OpenRouter API Key (get a free key at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter API URL (default: https://openrouter.ai/api/v1)
OPENROUTER_API_URL=https://openrouter.ai/api/v1

# OpenRouter Model Name — use a ":free" model for zero cost
# Free model examples: mistralai/mistral-7b-instruct:free
#                      google/gemma-3-1b-it:free
#                      meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_MODEL_NAME=mistralai/mistral-7b-instruct:free

# OpenAI API Key (optional - leave empty for Ollama)
OPENAI_API_KEY=your_openai_api_key_here

# Ollama API URL (default: http://localhost:11434/api)
OLLAMA_API_URL=http://localhost:11434/api

# Ollama Model Name (default: llama3)
OLLAMA_MODEL_NAME=llama3

# Request timeout in seconds (default: 60)
REQUEST_TIMEOUT=60

# Maximum prompt length (default: 40000)
MAX_PROMPT_LENGTH=40000

# Maximum response length (default: 2000)
MAX_RESPONSE_LENGTH=2000

# Enable conversation history (default: true)
ENABLE_HISTORY=true

# Enable streaming responses (default: false)
ENABLE_STREAMING=false

# Enable debug logging (default: false)
DEBUG_LOG=false

# Enable CORS for development (default: false)
ENABLE_CORS=false

# Enable CSP strict mode (default: false)
CSP_STRICT_MODE=false

# Output optimization level (0-3, default: 2)
OPTIMIZATION_LEVEL=2

# Enable LTO (default: true)
ENABLE_LTO=true
